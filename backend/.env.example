# Copy this file to ".env" and fill in real values when integrating IBM watsonx.ai

# --- IBM watsonx.ai (Granite model) credentials — used later in rag.py ---
WATSONX_API_KEY=your_ibm_watsonx_api_key_here
WATSONX_PROJECT_ID=your_ibm_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# --- Flask server config ---
PORT=5000
